# GPIO Pins (mode BCM)
TRIG_PIN=23
ECHO_PIN=24

# Hauteur physique de la poubelle (cm)
BIN_HEIGHT_CM=60

# URL de l'API SmartWaste
SMARTWASTE_API_URL=http://192.168.1.100:5000/api/bin-data

# Clé API (doit correspondre à PI_API_KEY dans le .env du serveur)
SMARTWASTE_PI_API_KEY=dev-pi-secret-key-2024

# ID de la poubelle dans la base de données
SMARTWASTE_BIN_ID=1

# Intervalle de mesure (secondes) — 600 = 10 minutes
INTERVAL_SECONDS=600

# Pour le simulateur seulement
NUM_BINS=3
